# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local working files — intentionally not versioned. `docs/` holds the violin
# source drafts and `scripts/` the dev tooling; the live content already lives in
# data/violins.ts and the i18n dictionaries, so these stay local by choice.
docs
scripts

# image backup (originals, not deployed)
/image-originals-backup/